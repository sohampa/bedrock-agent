# Copy to .env.local (gitignored) for local `agentcore dev`
GITHUB_TOKEN=ghp_your_token_here

# Optional Bedrock model (on-demand). Examples:
#   amazon.nova-lite-v1:0   (default, fast/cheap)
#   amazon.nova-pro-v1:0    (stronger)
#   amazon.nova-micro-v1:0  (smallest)
# BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
